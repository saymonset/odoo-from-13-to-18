# Ignorar respaldos de bases de datos y datos de todos los clientes y versiones
/arquitectura/odoo*/clientes/*/respaldo_db/
/arquitectura/odoo*/clientes/*/respaldo_db/*
/arquitectura/odoo*/clientes/*/data/
/arquitectura/odoo*/clientes/*/data/*
/arquitectura/odoo*/clientes/*/respaldo_odoo/
/arquitectura/odoo*/clientes/*/respaldo_odoo/*

# Ignorar backups automáticos de Odoo (carpeta out)
/arquitectura/odoo*/backup/out/
/arquitectura/odoo*/backup/out/*
/arquitectura/odoo19/v19test/*
# Excepción: mantener la estructura de carpetas
!/arquitectura/odoo*/backup/out/.gitkeep
!/arquitectura/odoo*/backup/out/README.md

# Ignorar entornos virtuales de todas las versiones
/arquitectura/odoo*/.venv

# Ignorar carpetas de código fuente de Odoo descargadas o clonadas
/arquitectura/odoo*/odoo

# Ignorar carpetas específicas de clientes (por ejemplo, enterprise, log, etc.)
/arquitectura/odoo*/clientes/*/log/
/arquitectura/odoo*/clientes/*/extra-addons/enterprise

# (Opcional) Ignorar todos los archivos .pyc y carpetas __pycache__ en cualquier parte del proyecto
# **/__pycache__/
# /**/*.pyc

# /arquitectura/odoo*/clientes/*/extra-addons/*/*/*.py
# /arquitectura/odoo*/clientes/*/extra-addons/*/*/*/*.py
/arquitectura/odoo*/clientes/cliente1/extra-addons/extra/react-odoo/generated/*
!/arquitectura/odoo*/clientes/cliente1/extra-addons/extra/react-odoo/generated/.gitkeep
/arquitectura/odoo*/clientes/*/sessions/filestore/**
/arquitectura/odoo*/clientes/*/sessions/sessions/**
/arquitectura/odoo18/clientes/cliente1/extra-addons/extra/chatter_voice_note/uses_cases/__pycache__/**
/arquitectura/odoo18/clientes/cliente1/extra-addons/oca/**/*
/arquitectura/odoo19/clientes/integraiadev/extra-addon/

# Excepciones para permitir el rastreo de data y log en integraiadev_19
!/arquitectura/odoo19/clientes/integraiadev_19/data/
!/arquitectura/odoo19/clientes/integraiadev_19/data/**
!/arquitectura/odoo19/clientes/integraiadev_19/log/
!/arquitectura/odoo19/clientes/integraiadev_19/log/**
