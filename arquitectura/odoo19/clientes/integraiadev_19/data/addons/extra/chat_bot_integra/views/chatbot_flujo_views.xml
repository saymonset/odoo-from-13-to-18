<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree view for chatbot.flujo -->
        <record id="view_chatbot_flujo_list" model="ir.ui.view">
            <field name="name">chatbot.flujo.list</field>
            <field name="model">chatbot.flujo</field>
            <field name="arch" type="xml">
                <list string="Flujos de Chatbot">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form view for chatbot.flujo -->
        <record id="view_chatbot_flujo_form" model="ir.ui.view">
            <field name="name">chatbot.flujo.form</field>
            <field name="model">chatbot.flujo</field>
            <field name="arch" type="xml">
                <form string="Flujo de Chatbot">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <notebook>
                            <page string="Pasos">
                                <field name="paso_ids">
                                    <list editable="bottom">
                                        <field name="secuencia"/>
                                        <field name="nombre_interno"/>
                                        <field name="nombre_mostrar"/>
                                        <field name="tipo_dato"/>
                                        <field name="campo_destino"/>
                                        <field name="es_requerido"/>
                                        <!-- <field name="mensaje_prompt"/>
                                        <field name="mensaje_error"/> -->
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action to open chatbot.flujo -->
        <record id="action_chatbot_flujo" model="ir.actions.act_window">
            <field name="name">Flujos de Chatbot</field>
            <field name="res_model">chatbot.flujo</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>