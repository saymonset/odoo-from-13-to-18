<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================== 1. LISTADO DE PRODUCTOS ======================== -->
    <template id="products_item_price_usd" inherit_id="website_sale.products_item" name="Product Grid Price with USD">
        <xpath expr="//div[hasclass('product_price')]" position="after">
            <div class="product_price_usd text-muted small mt-1">
                <t t-set="usd_currency" t-value="website.env['res.currency'].search([('name','=','USD')], limit=1)"/>
                <span t-out="product.list_price * website.get_conversion_factor_ves_to_usd()"
                      t-options="{'widget': 'monetary', 'display_currency': usd_currency}"/>
            </div>
        </xpath>
        <!-- Agregar información de la tasa BCV debajo del precio en USD -->
        <xpath expr="//div[hasclass('product_price')]" position="after">
            <div class="bcv_rate_hint text-muted small mt-1" style="font-size: 0.7rem;">
                <t t-set="bcv_info" t-value="website.get_bcv_rate_info()"/>
                <i class="fa fa-info-circle"></i>
                <span t-out="bcv_info['rate_display']"/>
                <t t-if="bcv_info['date_formatted']"> (<t t-out="bcv_info['date_formatted']"/>)</t>
            </div>
        </xpath>
    </template>

    <!-- ======================== 2. PÁGINA DE DETALLE DEL PRODUCTO ======================== -->
    <template id="product_price_usd" inherit_id="website_sale.product_price" name="Product Detail Price with USD">
        <xpath expr="//div[@name='product_price_container']" position="after">
            <div class="text-muted small mt-1">
                <t t-set="usd_currency" t-value="website.env['res.currency'].search([('name','=','USD')], limit=1)"/>
                <span t-out="combination_info['price'] * website.get_conversion_factor_ves_to_usd()"
                      t-options="{'widget': 'monetary', 'display_currency': usd_currency}"/>
            </div>
        </xpath>
        <!-- Agregar tasa BCV debajo del precio en USD en detalle -->
        <xpath expr="//div[@name='product_price_container']" position="after">
            <div class="bcv_rate_hint text-muted small mt-1" style="font-size: 0.8rem;">
                <t t-set="bcv_info" t-value="website.get_bcv_rate_info()"/>
                <i class="fa fa-info-circle"></i>
                <strong>Tasa de cambio oficial:</strong> <span t-out="bcv_info['rate_display']"/>
                <t t-if="bcv_info['date_formatted']"> (vigente al <t t-out="bcv_info['date_formatted']"/>)</t>
            </div>
        </xpath>
    </template>

    <!-- ======================== 3. LÍNEAS DEL CARRITO ======================== -->
    <template id="cart_lines_price_usd" inherit_id="website_sale.cart_lines_price" name="Cart Lines Price with USD">
        <xpath expr="//h6[@name='website_sale_cart_line_price']" position="after">
            <div class="d-md-none text-muted small mt-1">
                <span t-field="line.price_subtotal_usd_bcv"
                    t-options="{'widget': 'monetary', 'display_currency': website_sale_order.currency_aux}"/>
            </div>
            <div class="d-none d-md-block text-end text-muted small">
                <span t-field="line.price_subtotal_usd_bcv"
                    t-options="{'widget': 'monetary', 'display_currency': website_sale_order.currency_aux}"/>
            </div>
        </xpath>
    </template>

    <!-- ======================== 4. RESUMEN LATERAL DEL CARRITO (filas de productos) ======================== -->
    <template id="cart_summary_content_usd" inherit_id="website_sale.cart_summary_content" name="Cart Summary with USD">
        <xpath expr="//td[hasclass('td-price')]" position="after">
            <td class="td-price-usd pe-0 pt-3 text-end">
                <span t-field="line.price_subtotal_usd_bcv"
                      t-options="{'widget': 'monetary', 'display_currency': website_sale_order.currency_aux}"/>
            </td>
        </xpath>
    </template>

    <!-- ======================== 5. TOTALES DEL CARRITO + TASA BCV ======================== -->
    <template id="total_usd" inherit_id="website_sale.total" name="Total with USD">
        <xpath expr="//tr[@name='o_order_total']" position="after">
            <!-- Fila para el total en USD -->
            <tr name="o_order_total_usd">
                <td colspan="2" class="border-0 ps-0 pt-2">
                    <strong>Total</strong>
                </td>
                <td class="text-end border-0 px-0 pt-2">
                    <strong t-field="website_sale_order.amount_total_usd"
                            t-options="{'widget': 'monetary', 'display_currency': website_sale_order.currency_aux}"/>
                </td>
            </tr>
            <!-- Fila para mostrar la tasa BCV (información transparente) -->
            <tr name="bcv_rate_info_row" class="small text-muted">
                <td colspan="3" class="border-0 ps-0 pt-1 pb-0">
                    <t t-set="bcv_info" t-value="website.get_bcv_rate_info()"/>
                    <i class="fa fa-info-circle me-1"></i>
                    <span t-out="bcv_info['rate_display']"/>
                    <t t-if="bcv_info['date_formatted']">
                        (vigente al <t t-out="bcv_info['date_formatted']"/>)
                    </t>
                    <br/>
                    <span>Los precios en USD se calculan usando esta tasa oficial.</span>
                </td>
            </tr>
            <tr style="display:none;">
                <td colspan="3">
                    <span id="original_amount_vef" t-out="website_sale_order.amount_total"/>
                    <span id="original_amount_usd" t-out="website_sale_order.amount_total_usd"/>
                    <span id="bcv_exchange_rate" t-out="website.get_bcv_rate_info().get('rate', 0)"/>
                    <span id="bcv_rate_date" t-out="website.get_bcv_rate_info().get('date_formatted', '')"/>
                </td>
            </tr>
        </xpath>
    </template>

    <!-- ======================== 6. FOOTER GLOBAL (aparece en todas las páginas) ======================== -->
    <template id="bcv_rate_info_footer" inherit_id="website.layout" name="BCV Rate Info in Footer">
        <xpath expr="//footer" position="inside">
            <div class="container mt-3 text-center small text-muted border-top pt-2">
                <t t-set="bcv_info" t-value="website.get_bcv_rate_info()"/>
                <i class="fa fa-exchange-alt"></i>
                <strong>Tasa BCV oficial:</strong> <span t-out="bcv_info['rate_display']"/>
                <t t-if="bcv_info['date_formatted']"> (actualizada el <t t-out="bcv_info['date_formatted']"/>)</t>
            </div>
        </xpath>
    </template>

</odoo>