<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="conver_pos_sales.PaymentProofComponent" owl="1">
        <div class="mt-3" t-if="state.showSection">
        <!-- Spinner de carga -->
            <div t-if="state.loading" class="text-center p-4">
                <i class="fa fa-spinner fa-spin fa-2x"></i>
                <p class="mt-2">Cargando información de pago...</p>
            </div>

            <!-- Formulario normal -->
            <div t-else="">
                        <div class="alert alert-info">
                            <strong>Instrucciones de pago:</strong><br/>
                            Realice su transferencia o pago móvil a:<br/>
                            Banco: ... / Teléfono: ... / Cédula: ...<br/>
                            Luego adjunte el comprobante.
                        </div>

                        <!-- Fecha y método -->
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label for="payment_date" class="form-label">Fecha de pago</label>
                                <input type="date" class="form-control" id="payment_date"
                                    t-att-value="state.payment_date" t-on-change="_updateField" data-field="payment_date"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="payment_method" class="form-label">Forma de pago</label>
                                <select class="form-control" id="payment_method"
                                        t-on-change="_updateField" data-field="payment_method">
                                    <option value="movil" t-att-selected="state.payment_method == 'movil'">Pago móvil</option>
                                    <option value="transfer" t-att-selected="state.payment_method == 'transfer'">Transferencia</option>
                                    <option value="other" t-att-selected="state.payment_method == 'other'">Otro</option>
                                </select>
                            </div>
                        </div>

                        <!-- Bancos -->
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label for="bank_origin" class="form-label">Banco origen</label>
                                <select class="form-control" id="bank_origin"
                                        t-on-change="_updateField" data-field="bank_origin">
                                    <option value="">Seleccione un banco</option>
                                    <t t-foreach="state.bankList" t-as="bank" t-key="bank.id">
                                        <option t-att-value="bank.id" t-att-selected="state.bank_origin == bank.id">
                                            <t t-esc="bank.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="bank_destination" class="form-label">Banco destino</label>
                                <input type="text" class="form-control" id="bank_destination"
                                    t-att-value="state.bank_destination" t-on-change="_updateField" data-field="bank_destination"/>
                            </div>
                        </div>

                        <!-- Referencia -->
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label for="reference" class="form-label">Referencia</label>
                                <input type="text" class="form-control" id="reference"
                                    t-att-value="state.reference" t-on-change="_updateField" data-field="reference"/>
                            </div>
                        </div>

                        <!-- ========== CAMPOS DE MONTO (EDITABLES) ========== -->
                        <div class="row g-3">
                            <div class="col-md-4 mb-3">
                                <label for="amount_vef" class="form-label">Monto en bolívares</label>
                                <!-- Cambiado a type="text" para manejar comas/puntos -->
                                <input type="text" class="form-control" id="amount_vef"
                                    t-att-value="state.amount_vef" t-on-input="_onAmountVefInput"/>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label for="exchange_rate" class="form-label">Tasa de cambio (BCV)</label>
                                <input type="number" step="0.0001" class="form-control" id="exchange_rate"
                                    t-att-value="state.exchange_rate" readonly="readonly" disabled="disabled"/>
                                <div class="text-muted small" t-if="state.rate_date">
                                    <i class="fa fa-calendar"></i> Vigente al <t t-esc="state.rate_date"/>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label for="amount_usd" class="form-label">Monto USD</label>
                                <!-- Cambiado a type="text" para manejar comas/puntos -->
                                <input type="text" class="form-control" id="amount_usd"
                                    t-att-value="state.amount_usd" t-on-input="_onAmountUsdInput"/>
                            </div>
                        </div>

                        <!-- Alerta de validación (fuera del row) -->
                        <div t-if="!state.is_valid_amount and !state.loading" class="alert alert-danger mt-2">
                            <i class="fa fa-warning"></i> El monto en bolívares debe ser igual al total de la orden (<t t-esc="state.original_amount_vef"/> Bs.).
                        </div>
                        <!-- Campo de archivo -->
                        <div class="mb-3">
                            <label for="payment_proof_file" class="form-label">Comprobante de pago (imagen o PDF)</label>
                            <input type="file" id="payment_proof_file" accept="image/*,.pdf" class="form-control" t-on-change="_handleFileChange"/>
                            <div t-if="state.fileUploading" class="text-muted mt-1">
                                <i class="fa fa-spinner fa-spin me-1"/> Subiendo...
                            </div>
                            <div t-if="state.uploadError" class="text-danger mt-1">
                                <t t-esc="state.uploadError"/>
                            </div>
                        </div>
                    </div>
        </div>
    </t>
</templates>