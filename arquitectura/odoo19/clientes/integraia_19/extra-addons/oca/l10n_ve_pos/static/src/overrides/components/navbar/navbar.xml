                <img class="pos-logo h-75 ms-3 me-auto align-self-center" t-on-click="() => debug.toggleWidget()" src="/web/static/img/logo.png" alt="Logo" />
                <div class="pt-1 ms-2 align-self-center">
            |
                </div>
                <img class="pos-logo h-50 ms-3 me-auto align-self-center" src="/l10n_ve_pos/static/src/img/binaural.png" alt="Logo" />
            </div>
        </xpath>
    </t>
</templates>
