<templates id="template" xml:space="preserve">
  <t t-name="l10n_ve_pos.ProductCardExt"
     t-inherit="point_of_sale.ProductCard"
     t-inherit-mode="extension"
     owl="1">

    <!-- Debajo del bloque principal del card -->
    <xpath expr="//div[contains(@class, 'product-content')]" position="after">
      <t t-if="show_free_qty and pos">
        <div class="free-qty p-1" style="display:block; width:100%; margin-top:4px;"
             t-attf-style="{{ free_qty &gt; 0 and 'color: green' or 'color: red' }}">
          Disponible:
          <t t-if="stockStatus === 'success' or stockStatus === 'idle'">
            <t t-esc="free_qty"/>
          </t>
          <t t-elif="stockStatus === 'error'">N/A</t>
          <t t-else="">
            <i class="fa fa-fw fa-spin fa-circle-o-notch" aria-hidden="true"/>
          </t>
        </div>
      </t>
    </xpath>

  </t>
</templates>