<odoo>
    <template id="report_iva_customer">
        <!--Header-->
        <div class="container" style="font-size:12px !important;">
            <div class="row">
                <div class="col-3">
                    <t t-if="res_company.logo">
                        <img style="max-height:100px;width:200px;float:left"
                             t-att-src="image_data_uri(res_company.logo)"/>
                    </t>
                    <t t-else="">
                        <div style="max-height:100px;width:200px;float:left"></div>
                    </t>
                </div>
                <h3 t-if="retention.state == 'cancel'" style="position:absolute;left:65px;top:250px;font-size:260px !important;opacity: 0.1;">ANULADA</h3>
                <div class="col-8" style="text-align: left;">
                    <h6>COMPROBANTE DE RETENCIÓN DEL IMPUESTO AL VALOR AGREGADO</h6>
                    <p>"Decreto con Rango, Valor y Fuerza de Ley de Reforma de la Ley del Impuesto al Valor agregado
                        Nro 1.436 del 17 de Noviembre del 2014"
                        Articulo 11: La Administracion Tributaria podra Designar como Responsable del Pago del
                        Impuesto, en calidad de Agentes de Retencion a quienes por sus
                        Funciones Publicas o por Razón de sus Actividades Privadas intervengan en operaciones
                        Gravadas con el Impuesto Establecido en este Decreto con Rango,
                        Valor y Fuerza de Ley.
                    </p>
                </div>
            </div>

            <div class="row justify-content-end" style="margin-top:5px">
                <div class="col-4">
                    <span>Nro Comprobante:</span>
                    <div>
                        <span t-esc="retention.number"/>
                    </div>
                </div>
                <div class="col-4">
                    <span>Fecha de emision:</span>
                    <div>
                        <span t-esc="retention.date" t-options='{"widget": "date"}'/>
                    </div>
                </div>
            </div>
            <div class="row" style="margin-top:10px">
                <div class="col-4">
                    <div class="col-12">
                        <span>Nombre o Razón Social del Agente de Retención</span>
                        <div style="width:100%">
                            <span t-esc="res_company.name"/>
                        </div>
                    </div>
                    <div class="col-12">
                        <span>Direccion Fiscal del Agente de Retención</span>
                        <div class="col-12">
                            <span t-esc="res_company.street"/>
                            <span t-esc="res_company.street2"/>
                            <span t-esc="res_company.state_id.name"/>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="col-12">
                        <span>Registro de Informacion Fiscal del Agente de Retención:</span>
                    </div>
                    <div>
                        <span t-esc="res_company.vat"/>
                    </div>
                </div>

                <div class="col-4">
                    <div class="col-12">
                        <span>Periodo Fiscal:</span>
                        <div style="width:100%">Año :
                            <span t-esc="retention.date_accounting.strftime('%Y')"/>
                            / Mes:
                            <span t-esc="retention.date_accounting.strftime('%m')"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!--Body-->

        <!--Separator-->
        <div class="container">
            <div class="row">
                <hr class="" style="color:black"/>
            </div>
        </div>

        <!--Information Client-->
        <div class="container" style="font-size:12px !important;">
            <div class="row">
                <div class="col-6">
                    <span>Nombre o Razón Social del Sujeto Retenido</span>
                    <div>
                        <span t-esc="retention.partner_id.name"/>
                    </div>
                </div>
                <div class="col-6">
                    <span>Registro de Información Fiscal del Sujeto Retenido (R.I.F)</span>
                    <div>
                        <span style="text-transform:uppercase"
                              t-esc="retention.partner_id.prefix_vat+retention.partner_id.vat"/>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-6">
                    <span>Direccion Fiscal del Sujeto Retenido</span>
                    <div>
                        <span t-esc="retention.partner_id.street"/>
                        <t t-if="retention.partner_id.street2">
                            ,
                            <span t-esc="retention.partner_id.street2"/>
                        </t>
                    </div>
                </div>
            </div>
        </div>

        <style>
        .ret-table { width:100%; table-layout:fixed; border-collapse:separate; border-spacing:0; box-sizing:border-box; font-family:sans-serif; -webkit-print-color-adjust:exact; -webkit-font-smoothing:antialiased; }
        .ret-table col { box-sizing:border-box; }
        .ret-table th, .ret-table td { border:none !important; padding:4px 6px; vertical-align:middle; font-size:10px; }
        .ret-left { text-align:left; }
        .ret-num { text-align:right; }
        .no-wrap { white-space:nowrap; }
        .ret-num span { display:inline-block; }
        .sep-cell { padding:0; }
        </style>

        <table class="ret-table" role="presentation" aria-hidden="true">
            <colgroup>
                <col style="width:60px"/>   <!-- 1 Fecha Factura -->
                <col style="width:60px"/>   <!-- 2 Número de Factura -->
                <col style="width:70px"/>   <!-- 3 Nro de Control Factura -->
                <col style="width:70px"/>   <!-- 4 Nota de Débito -->
                <col style="width:70px"/>   <!-- 5 Nota de Crédito -->
                <col style="width:80px"/>   <!-- 6 Tipo de Transacción -->
                <col style="width:90px"/>   <!-- 7 Factura afectada -->
                <col style="width:110px"/>  <!-- 8 Total Compras Incluyendo el IVA -->
                <col style="width:100px"/>  <!-- 9 Compras sin derecho a Crédito IVA -->
                <col style="width:100px"/>  <!-- 10 Base Imponible -->
                <col style="width:60px"/>   <!-- 11 % Alic -->
                <col style="width:60px"/>   <!-- 12 % Ret -->
                <col style="width:90px"/>   <!-- 13 Impuesto IVA -->
                <col style="width:110px"/>  <!-- 14 IVA Retenido -->
            </colgroup>

            <thead style="font-size:12px;">
                <tr>
                    <th style="padding:4px 6px; text-align:left;">Fecha Factura</th>
                    <th style="padding:4px 6px; text-align:right;">Número de Factura</th>
                    <th style="padding:4px 6px; text-align:right;">Nro de Control Factura</th>
                    <th style="padding:4px 6px; text-align:right;">Nota de Débito</th>
                    <th style="padding:4px 6px; text-align:right;">Nota de Crédito</th>
                    <th style="padding:4px 6px; text-align:right;">Tipo de Transacción</th>
                    <th style="padding:4px 6px; text-align:right;">Factura afectada</th>
                    <th style="padding:4px 6px; text-align:right;">Total Compras Incluyendo el IVA</th>
                    <th style="padding:4px 6px; text-align:right;">Compras sin derecho a Crédito IVA</th>
                    <th style="padding:4px 6px; text-align:right;">Base Imponible</th>
                    <th style="padding:4px 6px; text-align:right;">% Alic</th>
                    <th style="padding:4px 6px; text-align:right;">% Ret</th>
                    <th style="padding:4px 6px; text-align:right;">Impuesto IVA</th>
                    <th style="padding:4px 6px; text-align:right;">IVA Retenido</th>
                </tr>

                <!-- separador header|body (SVG en fila colspan=14) -->
                <tr role="separator">
                    <td class="sep-cell" colspan="14" style="padding:0">
                        <svg width="100%" height="2" viewBox="0 0 1000 2" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block">
                            <rect x="0" y="0" width="1000" height="1" fill="#000"/>
                        </svg>
                    </td>
                </tr>
            </thead>

            <tbody>
                <t t-set="total_amount_total" t-value="0"/>
                <t t-set="total_amount_amount_except" t-value="0"/>
                <t t-set="invoice_amount" t-value="0"/>            <!-- suma Base Imponible -->
                <t t-set="total_amount_tax" t-value="0"/>          <!-- suma Impuesto IVA -->
                <t t-set="total_amount_to_pay" t-value="0"/>       <!-- suma IVA Retenido -->

                <t t-foreach="retention.retention_line_ids" t-as="line">
                    <tr>
                        <!-- 1 Fecha Factura -->
                        <td class="ret-left">
                            <t t-if="line.move_id.invoice_date_display"><span t-esc="line.move_id.invoice_date_display.strftime('%d/%m/%Y')"/></t><t t-else="">--</t>
                        </td>

                        <!-- 2 Número de Factura -->
                        <td class="ret-num">
                            <t t-if="line.move_id.move_type in ['out_invoice','out_contingence','in_invoice'] and not line.move_id.journal_id.is_debit">
                                <span t-esc="line.move_id.name"/>
                            </t>
                            <t t-else="">--</t>
                        </td>

                        <!-- 3 Nro de Control Factura -->
                        <td class="ret-num"><span t-esc="line.move_id.correlative or '--'"/></td>

                        <!-- 4 Nota de Débito -->
                        <td class="ret-num">
                            <t t-if="line.move_id.journal_id.is_debit"><span t-esc="line.move_id.name"/></t><t t-else="">--</t>
                        </td>

                        <!-- 5 Nota de Crédito -->
                        <td class="ret-num">
                            <t t-if="line.move_id.move_type in ('out_refund','in_refund')"><span t-esc="line.move_id.name"/></t><t t-else="">--</t>
                        </td>

                        <!-- 6 Tipo de Transacción -->
                        <td class="ret-num">
                            <t t-if="line.move_id.move_type in ('out_invoice','in_invoice') and line.move_id.state == 'posted'">
                                <t t-if="line.move_id.journal_id.is_debit">02-REG</t><t t-else="">01-REG</t>
                            </t>
                        <t t-elif="line.move_id.move_type in ('out_debit','in_debit') and line.move_id.state == 'posted'">02-REG</t>
                        <t t-elif="line.move_id.move_type in ('out_refund','in_refund') and line.move_id.state == 'posted'">03-REG</t>
                        <t t-elif="line.move_id.move_type in ('out_refund','out_debit','out_invoice','in_refund','in_debit','in_invoice') and line.move_id.state in ('cancel')">03-ANU</t>
                        <t t-else="">--</t>
                        </td>

                        <!-- 7 Factura afectada -->
                        <td class="ret-num">
                            <t t-if="line.move_id.move_type in ('in_refund','out_refund') and line.move_id.reversed_entry_id"><span t-esc="line.move_id.reversed_entry_id.name"/></t>
                            <t t-elif="line.move_id.journal_id.is_debit"><span t-esc="line.move_id.debit_origin_id.name"/></t>
                            <t t-else="">--</t>
                        </td>

                        <!-- 8 Total Compras Incluyendo el IVA -->
                        <td class="ret-num">
                            <t t-if="foreign_currency_is_vef">
                                <span t-esc="line.foreign_invoice_total" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_total" t-value="total_amount_total + line.foreign_invoice_total"/>
                            </t>
                            <t t-else="">
                                <span t-esc="line.invoice_total" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_total" t-value="total_amount_total + line.invoice_total"/>
                            </t>
                        </td>

                        <!-- 9 Compras sin derecho a Crédito IVA -->
                        <td class="ret-num">
                            <t t-if="foreign_currency_is_vef">
                                <t t-set="amount_except" t-value="sum(line.move_id.invoice_line_ids.filtered(lambda l: l.tax_ids.amount == 0).mapped('foreign_subtotal'))"/>
                            </t>
                            <t t-else="">
                                <t t-set="amount_except" t-value="sum(line.move_id.invoice_line_ids.filtered(lambda l: l.tax_ids.amount == 0).mapped('price_subtotal'))"/>
                            </t>
                            <span t-esc="amount_except" t-options='{"widget":"float","precision":get_digits}'/>
                            <t t-set="total_amount_amount_except" t-value="total_amount_amount_except + amount_except"/>
                        </td>

                        <!-- 10 Base Imponible -->
                        <td class="ret-num">
                            <t t-if="foreign_currency_is_vef">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.foreign_invoice_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="invoice_amount" t-value="invoice_amount - line.foreign_invoice_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.foreign_invoice_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="invoice_amount" t-value="invoice_amount + line.foreign_invoice_amount"/>
                                </t>
                            </t>
                            <t t-else="">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.invoice_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="invoice_amount" t-value="invoice_amount - line.invoice_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.invoice_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="invoice_amount" t-value="invoice_amount + line.invoice_amount"/>
                                </t>
                            </t>
                        </td>

                        <!-- 11 % Alic -->
                        <td class="ret-num no-wrap"><span t-esc="line.aliquot"/></td>

                        <!-- 12 % Ret -->
                        <td class="ret-num no-wrap"><span t-esc="line.related_percentage_tax_base"/></td>

                        <!-- 13 Impuesto IVA -->
                        <td class="ret-num">
                            <t t-if="foreign_currency_is_vef">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.foreign_iva_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_tax" t-value="total_amount_tax - line.foreign_iva_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.foreign_iva_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_tax" t-value="total_amount_tax + line.foreign_iva_amount"/>
                                </t>
                            </t>
                            <t t-else="">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.iva_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_tax" t-value="total_amount_tax - line.iva_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.iva_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_tax" t-value="total_amount_tax + line.iva_amount"/>
                                </t>
                            </t>
                        </td>

                        <!-- 14 IVA Retenido -->
                        <td class="ret-num no-wrap">
                            <t t-if="foreign_currency_is_vef">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.foreign_retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_to_pay" t-value="total_amount_to_pay - line.foreign_retention_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.foreign_retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_to_pay" t-value="total_amount_to_pay + line.foreign_retention_amount"/>
                                </t>
                            </t>
                            <t t-else="">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_to_pay" t-value="total_amount_to_pay - line.retention_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="total_amount_to_pay" t-value="total_amount_to_pay + line.retention_amount"/>
                                </t>
                            </t>
                        </td>
                    </tr>
                </t>

                <!-- separador body|footer (SVG in colspan=14) -->
                <tr role="separator">
                    <td class="sep-cell" colspan="14" style="padding:0">
                        <svg width="100%" height="2" viewBox="0 0 1000 2" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block">
                            <rect x="0" y="0" width="1000" height="1" fill="#000"/>
                        </svg>
                    </td>
                </tr>
            </tbody>

            <tfoot>
                <!-- Footer row: mostramos las sumas en las columnas correspondientes:
                    Base Imponible (col 10), Impuesto IVA (col 13), IVA Retenido (col 14) -->
                <tr>
                    <td colspan="9"></td>

                    <!-- 10 Base Imponible (suma) -->
                    <td style="padding:6px 4px; text-align:right; border-top:0;">
                        <span t-esc="invoice_amount" t-options='{"widget":"float","precision":get_digits}'/>
                    </td>

                    <!-- 11 % Alic (vacío) -->
                    <td style="padding:6px 4px; border-top:0;"></td>

                    <!-- 12 % Ret (vacío) -->
                    <td style="padding:6px 4px; border-top:0;"></td>

                    <!-- 13 Impuesto IVA (suma) -->
                    <td style="padding:6px 4px; text-align:right; border-top:0;">
                        <span t-esc="total_amount_tax" t-options='{"widget":"float","precision":get_digits}'/>
                    </td>

                    <!-- 14 IVA Retenido (suma) -->
                    <td style="padding:6px 4px; text-align:right; border-top:0;">
                        <span t-esc="float(total_amount_to_pay)" t-options='{"widget":"float","precision":get_digits}'/>
                    </td>
                </tr>
            </tfoot>
        </table>

        <!--Firmas-->
        <div class="container" style="font-size:12px !important;">
            <div class="row text-center">
                <div class="col-5" style="width:35%; margin-top:10px;">
                    <!--Firma digital-->
                    <div style="height:100px">
                        <img style="max-height:120px;width:200px" t-if="retention.get_signature()"
                             t-att-src="'data:image/png;base64,%s' % retention.get_signature()"/>
                    </div>
                    <!--Firma digital fin-->
                    <h6 style="text-align: center; margin: 30px 0;border-top: 1px solid #000;width:80%; padding-top:10px;">
                        Agente de Retención
                    </h6>
                </div>
                <div class="col-5" style="width:30%; margin-top:10px;">

                </div>
                <div class="col-5" style="width:35%;margin-top:10px;">
                    <div style="height:100px"></div>
                    <h6 style="text-align: center; margin: 30px 0;border-top: 1px solid #000;width:80%; padding-top:10px;">
                        Recibido por:
                    </h6>
                    <div style="height:30px"></div>
                    <h6 style="text-align: center; margin: 5px 0;width:80%; padding-top:10px;">Fecha de entrega:
                    </h6>
                </div>
            </div>
        </div>
    </template>


    <template id="report_islr_customer">
        <!--Header-->
        <div class="container" style="font-size:12px !important;">
            <div class="row">
                <div class="col-4">
                    <t t-if="res_company.logo">
                        <img style="max-height:100px;width:200px;float:left"
                             t-att-src="image_data_uri(res_company.logo)"/>
                    </t>
                    <t t-else="">
                        <div style="max-height:100px;width:200px;float:left"></div>
                    </t>
                </div>
                <h3 t-if="retention.state == 'cancel'" style="position:absolute;left:65px;top:250px;font-size:260px !important;opacity: 0.1;">ANULADA</h3>
                <div class="col-8">
                    <div class="col-12">
                        <h6>COMPROBANTE DE RETENCIÓN DE ISLR</h6>
                    </div>
                    <div class="col-12">
                        <span>Art. 24 del Drecreto 1808 Según G.O Nro 36.203 de fecha de mayo de 1997</span>
                    </div>
                <br />
                <div class="col-12 row justify-content-end" style="margin-top:8px">
                    <div class="col-4">
                        <span>Nro Comprobante:</span>
                        <div>
                            <span t-esc="retention.number"></span>
                        </div>
                    </div>
                    <div class="col-4">
                        <span>Fecha:</span>
                        <span t-esc="retention.date" t-options='{"widget": "date"}'/>
                    </div>
                    <div class="col-4">
                        <span>Periodo Fiscal:</span>
                        <div>
                            <span t-esc="retention.date.strftime('%m/%Y')"/>
                        </div>
                    </div>
                </div>

                </div>
            </div>
        </div>

        <!--Body-->
        <t t-set="imp" t-options='{"widget": "float", "precision": get_digits}' t-value='0' />

        <div class="container" style="font-size:12px !important;margin-top:10px!important">
            <div class="row">
                <div class="col-8">
                    <div class="col-12">
                        <span>Agente de Retención:</span>
                    </div>
                    <div class="col-12" style="text-transform:uppercase">
                        <span t-esc="res_company.name"/>
                    </div>
                    <div class="col-12">
                        <span>Dirección:</span>
                    </div>
                    <div class="col-12" style="text-transform:uppercase">
                        <span t-esc="res_company.street"/>
                    </div>
                </div>
                <div class="col-4">
                    <div class="col-12" >
                        <span>No. R.I.F.:</span>
                    </div>
                    <div class="col-12" style="text-transform:uppercase">
                        <span t-esc="res_company.vat"/>
                    </div>
                </div>
            </div>
        </div>

        <!--Separator-->
        <div class="container">
            <div class="row">
                <hr class="col-12" style="color:black"/>
            </div>
        </div>

        <!--Information Client-->
        <div class="container" style="font-size:12px !important;">
            <div class="row">
                <div class="col-8">
                    <div class="col-12">
                        <span>Contribuyente:</span>
                    </div>
                    <div class="col-12">
                        <span style="text-transform:uppercase" t-esc="retention.partner_id.name"/>
                    </div>
                </div>
                <div class="col-4" style="">
                    <div class="col-12">
                        <span>Nro. R.I.F.:</span>
                    </div>

                    <div class="col-12">
                        <span style="text-transform:uppercase"
                              t-esc="retention.partner_id.prefix_vat+retention.partner_id.vat"/>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-8">
                    <div class="col-12">
                        <span>Dirección:</span>
                    </div>
                    <div class="col-12" style="text-transform:uppercase">
                        <span t-esc="retention.partner_id.street"/>
                        <t t-if="retention.partner_id.street2">
                            ,
                            <span t-esc="retention.partner_id.street2"/>
                        </t>
                    </div>
                </div>
            </div>
        </div>

        <!--Line Retention: Description-->
        <!--Title-->
        <div class="container">
            <div class="text-center" style="font-weight: bold;margin-top:5px">
                <h6 style="text-transform:uppercase">información impuesto retenido</h6>
            </div>
        </div>

        <!-- Tabla de retenciones -->
        <style>
            .ret-table { width:100%; table-layout:fixed; border-collapse:separate; border-spacing:0; box-sizing:border-box; font-family:sans-serif; -webkit-print-color-adjust:exact; -webkit-font-smoothing:antialiased; }
            .ret-table col { box-sizing:border-box; }
            .ret-table th, .ret-table td { border:none !important; padding:4px 6px; vertical-align:middle; font-size:10px; }
            .ret-left { text-align:left; }
            .ret-num { text-align:right; }
            .no-wrap { white-space:nowrap; }
            .ret-num span { display:inline-block; } /* fuerza el span a respetar text-align y ancho */
            .sep-cell { padding:0; } /* para fila separadora */
        </style>


        <svg width="100%" height="2" viewBox="0 0 1000 2" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block">
          <rect x="0" y="0" width="1000" height="1" fill="#000"/>
        </svg>

        <table class="ret-table" role="presentation" aria-hidden="true">
            <colgroup>
                <col style="width:60px"/>   <!-- TD -->
                <col style="width:60px"/>   <!-- Fact Nro -->
                <col style="width:70px"/>   <!-- Nro de Control -->
                <col style="width:70px"/>   <!-- Fecha -->
                <col style="width:260px"/>  <!-- Concepto -->
                <col style="width:90px"/>   <!-- Total Factura -->
                <col style="width:90px"/>   <!-- Base de Retención -->
                <col style="width:70px"/>   <!-- Tarifa Ret -->
                <col style="width:80px"/>   <!-- Sustraendo -->
                <col style="width:110px"/>  <!-- Imp Retenido -->
            </colgroup>

            <thead>
                <tr>
                <th class="ret-left">TD</th>
                <th class="ret-left">Fact Nro</th>
                <th class="ret-left">Nro de Control</th>
                <th class="ret-left">Fecha</th>
                <th class="ret-left">Concepto</th>
                <th class="ret-left">Código de Retención</th>
                <th class="ret-num">Total Factura</th>
                <th class="ret-num">Base de Retención</th>
                <th class="ret-num">Tarifa Ret</th>
                <th class="ret-num">Sustraendo</th>
                <th class="ret-num">Imp Retenido</th>
                </tr>

                <!-- separador header|body (SVG en fila colspan=11) -->
                <tr role="separator">
                    <td class="sep-cell" colspan="11" style="padding:0">
                        <svg width="100%" height="2" viewBox="0 0 1000 2" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block">
                        <rect x="0" y="0" width="1000" height="1" fill="#000"/>
                        </svg>
                    </td>
                </tr>
            </thead>

            <tbody>
                <t t-set="islr_total" t-value="0"/>
                <t t-foreach="retention.retention_line_ids" t-as="line">
                    <tr>
                        <!-- TD -->
                        <td class="ret-left">
                            <t t-if="line.move_id.move_type in ('out_invoice','in_invoice')">FA</t>
                            <t t-elif="line.move_id.move_type == 'in_refund'">NC</t>
                            <t t-else="">ND</t>
                        </td>

                        <!-- Fact Nro -->
                        <td class="ret-left">
                            <t t-if="line.move_id and line.move_id.name"><span t-esc="line.move_id.name"/></t><t t-else="">--</t>
                        </td>

                        <!-- Nro de Control -->
                        <td class="ret-left"><span t-esc="line.move_id.correlative or '--'"/></td>

                        <!-- Fecha -->
                        <td class="ret-left">
                            <t t-if="line.move_id.invoice_date_display"><span t-esc="line.move_id.invoice_date_display.strftime('%d/%m/%Y')"/></t><t t-else="">--</t>
                        </td>

                        <!-- Concepto -->
                        <td class="ret-left"><span t-esc="line.payment_concept_id.name or '--'"/></td>

                        <!-- Código de Retención -->
                        <td class="ret-left"><span t-esc="line._get_code_of_retention() or '--'"/></td>

                        <!-- Total Factura -->
                        <td class="ret-num">
                            <t t-if="foreign_currency_is_vef">
                                <span t-esc="line.foreign_invoice_total" t-options='{"widget":"float","precision":get_digits}'/>
                            </t>
                            <t t-else="">
                                <span t-esc="line.invoice_total" t-options='{"widget":"float","precision":get_digits}'/>
                            </t>
                        </td>

                        <!-- Base de Retención -->
                        <td class="ret-num">
                            <t t-if="foreign_currency_is_vef">
                                <span t-esc="line.foreign_invoice_amount" t-options='{"widget":"float","precision":get_digits}'/>
                            </t>
                            <t t-else="">
                                <span t-esc="line.invoice_amount" t-options='{"widget":"float","precision":get_digits}'/>
                            </t>
                        </td>

                        <!-- Tarifa Ret (no-wrap para evitar salto de línea del %) -->
                        <td class="ret-num no-wrap">
                            <span t-esc="line.related_percentage_fees"/>%
                        </td>

                        <!-- Sustraendo -->
                        <td class="ret-num">
                            <span t-esc="line.related_amount_subtract_fees" t-options='{"widget":"float","precision":2}'/>
                        </td>

                        <!-- Imp Retenido -->
                        <td class="ret-num no-wrap">
                            <t t-if="foreign_currency_is_vef">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.foreign_retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="islr_total" t-value="islr_total - line.foreign_retention_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.foreign_retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="islr_total" t-value="islr_total + line.foreign_retention_amount"/>
                                </t>
                            </t>
                            <t t-else="">
                                <t t-if="line.move_id.move_type in ('in_refund','out_refund')">
                                <span t-esc="-line.retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="islr_total" t-value="islr_total - line.retention_amount"/>
                                </t>
                                <t t-else="">
                                <span t-esc="line.retention_amount" t-options='{"widget":"float","precision":get_digits}'/>
                                <t t-set="islr_total" t-value="islr_total + line.retention_amount"/>
                                </t>
                            </t>
                        </td>
                    </tr>
                </t>

                <!-- separador body|footer (SVG en fila colspan=11) -->
                <tr role="separator">
                    <td class="sep-cell" colspan="11" style="padding:0">
                        <svg width="100%" height="2" viewBox="0 0 1000 2" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block">
                            <rect x="0" y="0" width="1000" height="1" fill="#000"/>
                        </svg>
                    </td>
                </tr>
            </tbody>

            <tfoot>
                <tr>
                    <td colspan="10"></td>
                    <td class="ret-num no-wrap">
                        <span t-esc="islr_total" t-options='{"widget":"float","precision":get_digits}'/>
                    </td>
                </tr>
            </tfoot>
        </table>

        <!--Firmas-->
        <div class="container" style="font-size:12px !important;">
            <div class="row text-center">
                <div class="col-5" style="width:35%;margin-top:10px;">
                    <div style="height:100px"></div>
                    <h6 style="text-align: center; margin: 30px 0;border-top: 1px solid #000;width:80%; padding-top:10px;">
                        Firma del Agente Retenido
                    </h6>
                </div>

                <div class="col-5" style="width:30%; margin-top:10px;">
                </div>

                <div class="col-5" style="width:35%; margin-top:10px;">
                    <!--Firma digital-->
                    <div style="height:100px">
                        <img style="max-height:120px;width:200px" t-if="retention.get_signature()"
                             t-att-src="'data:image/png;base64,%s' % retention.get_signature()"/>
                    </div>
                    <!--Firma digital fin-->
                    <h6 style="text-align: center; margin: 30px 0;border-top: 1px solid #000;width:80%; padding-top:10px;">
                        Firma del Agente de Retención
                    </h6>
                </div>
            </div>
        </div>
    </template>


    <template id="retention_voucher_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="retention">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <t t-if="retention.type_retention == 'iva'">
                            <t t-call="l10n_ve_payment_extension.report_iva_customer"/>
                        </t>
                        <t t-else="">
                            <t t-call="l10n_ve_payment_extension.report_islr_customer"/>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
