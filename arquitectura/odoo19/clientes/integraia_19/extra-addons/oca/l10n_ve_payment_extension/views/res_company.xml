<odoo>
    <record id="view_company_form" model="ir.ui.view">
	<field name="name">l10n.ve.payment.extensionres.company.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Tax Authorities Data" name="tax_authorities_data">
                    <group>
                        <group string="Configuration">
                            <field name="tax_authorities_name"/>
                            <field name="economic_activity_number"/>
                        </group>
                        <group string="Logo">
                            <field name="tax_authorities_logo" widget="image" class="oe_avatar" nolabel="1"/>
                        </group>
                    </group>
                    <group string="Municipal Retention Voucher Headers">
                        <field name="text_header_1_municipal_retention" widget="text"/>
                        <field name="text_header_2_municipal_retention" widget="text"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
