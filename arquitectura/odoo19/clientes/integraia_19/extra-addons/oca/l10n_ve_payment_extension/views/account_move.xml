<odoo>
    <data>
        <record id="account_move_form_l10n_ve_payment_extension" model="ir.ui.view">
            <field name="name">account.move.form.l10n.ve.payment.extension</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_shipping_id']" position="after">
                    <field
                        name="generate_iva_retention"
                        invisible="move_type not in ('in_invoice', 'in_receipt', 'in_refund')"
                    />
                    <field
                        name="is_third_party_retention"
                        string="Third Party Billing"
                        invisible="move_type not in ('in_invoice', 'in_receipt', 'in_refund')"
                    />
                    <field name="iva_voucher_number" readonly="1" invisible="move_type in ('entry')"/>
                    <field name="islr_voucher_number" readonly="1" invisible="move_type in ('entry')"/>
                    <field name="municipal_voucher_number" readonly="1" invisible="move_type in ('entry')"/>
                    <field name="base_currency_is_vef" invisible="1"/>
                    <field name="company_currency_id" invisible="1"/>
                    <field name="foreign_currency_id" invisible="1"/>
                    <field name="not_edit_islr_retention_lines" invisible="1"/>
                    <field name="not_edit_municipal_retention_lines" invisible="1"/>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button
                        name="action_view_third_party_iva_retentions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-balance-scale"
                        invisible="not is_third_party_retention or move_type not in ('in_invoice', 'in_receipt', 'in_refund')"
                    >
                        <field name="third_party_iva_retention_count" widget="statinfo" string="Third Party IVA Ret."/>
                    </button>
                    <button
                        name="action_view_third_party_islr_retentions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-university"
                        invisible="not is_third_party_retention or move_type not in ('in_invoice', 'in_receipt', 'in_refund')"
                    >
                        <field name="third_party_islr_retention_count" widget="statinfo" string="Third Party ISLR Ret."/>
                    </button>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page name="iva_retention" string="IVA Retentions">
                        <field name="retention_iva_line_ids" nolabel="1" readonly="1" context="{'type':'iva'}">
                            <list editable='bottom'>
                                <!-- Invisible Fields -->
                                <field name="invoice_type" column_invisible="True"/>
                                <field name="company_currency_id" column_invisible="True"/>
                                <field name="foreign_currency_id" column_invisible="True"/>
                                <field name="name"/>
                                <field name="move_id"/>
                                <field name="aliquot"/>
                                <field name="related_percentage_tax_base" optional="hide"/>
                                <!-- Amounts -->
                                <field
                                    name="invoice_total"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="invoice_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="iva_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="retention_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <!-- Foreign Amounts -->
                                <field
                                    name="foreign_invoice_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_iva_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_total"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_retention_amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="foreign_currency_rate" optional="hide"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </page>
                    <page name="islr_retention" string="ISLR Retentions">
                        <field
                            name="retention_islr_line_ids"
                            nolabel="1"
                            readonly="move_type not in ('in_invoice', 'in_refund') or (state != 'draft' or not_edit_islr_retention_lines)"
                            context="{'type':'islr'}"
                        >
                            <list editable='bottom'>
                                <!-- Invisible Fields -->
                                <field name="invoice_type" column_invisible="True"/>
                                <field name="company_currency_id" column_invisible="True"/>
                                <field name="foreign_currency_id" column_invisible="True"/>
                                <field name="name"/>
                                <field name="payment_concept_id"/>
                                <field
                                    name="invoice_total"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_total"
                                    force_save="1"
                                    readonly="1"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="related_pay_from" force_save="1" readonly="1"/>
                                <field name="related_percentage_tax_base" force_save="1" readonly="1"/>
                                <field name="related_percentage_fees" force_save="1" readonly="1"/>
                                <field name="related_amount_subtract_fees" force_save="1" readonly="1"/>
                                <field name="foreign_currency_rate" force_save="1" readonly="1" optional="hide"/>
                                <field
                                    name="retention_amount"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_retention_amount"
                                    widget="monetary"
                                    force_save="1"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="state"/>
                            </list>
                        </field>
                    </page>
                    <page name="municipal_retention" string="Municipal Retentions">
                        <field
                            name="retention_municipal_line_ids"
                            nolabel="1"
                            readonly="move_type not in ('in_invoice', 'in_refund') or (state != 'draft' or not_edit_municipal_retention_lines)"
                            context="{'type':'municipal'}">
                            <list editable='bottom'>
                                <field name="name" force_save="1" readonly="1"/>
                                <field name="economic_activity_id" force_save="1"/>
                                <field name="aliquot" readonly="1" force_save="1"/>
                                <field
                                    name="invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="invoice_total"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="retention_amount"
                                    readonly="1"
                                    force_save="1"
                                    widget="monetary"
                                    options="{'currency_field': 'company_currency_id'}"
                                    column_invisible="not parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_amount"
                                    force_save="1"
                                    string="Invoice Amount"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_invoice_total"
                                    force_save="1"
                                    readonly="1"
                                    widget="monetary"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field
                                    name="foreign_retention_amount"
                                    widget="monetary"
                                    force_save="1"
                                    options="{'currency_field': 'foreign_currency_id'}"
                                    column_invisible="parent.base_currency_is_vef"
                                />
                                <field name="foreign_currency_rate" force_save="1" readonly="1" optional="hide"/>
                                <field name="state" force_save="1"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
