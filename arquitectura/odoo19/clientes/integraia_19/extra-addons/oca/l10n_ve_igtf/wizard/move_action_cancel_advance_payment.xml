<odoo>
    <record id="move_action_cancel_advance_payment_wizard" model="ir.ui.view">
        <field name="name">move.action.cancel.advance.payment.wizard.form</field>
        <field name="model">move.action.cancel.advance.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Validation">
                <div class="oe_title"> 
                    
                    <h5>Unreconciling or Canceling this Payment/Entry will cancel the cross-entry entries (or cross moves) related to the payment.</h5>
                    
                </div>
                <group>
                    
                    <field name="move_id" string ="Factura" options="{'no_create': True}" readonly="1" force_save='True'/>
                    <field name="cross_move_ids" string ="Asientos de Cruce" widget="many2many_tags" options="{'no_create': True}" readonly="1"/>
                    <field name="payment_id" invisible="1" force_save='True'/>
                </group>
                <footer>
                    <button name="action_confirm" string="Accept" type="object" class="oe_highlight" />
                    <button name="action_cancel" string="Cancel" type="object" class="oe_secondary" />
                </footer>
            </form>
        </field>
    </record>
</odoo>