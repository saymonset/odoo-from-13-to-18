<odoo>
    <record id="res_config_settings_l10n_ve_igtf" model="ir.ui.view">
        <field name="name">res.config.settings.l10n_ve_igtf</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_ve_base.l10n_ve_base_view_res_config_settings" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='l10n_ve_base']" position="inside">
                
                <block title="Advance Payment" name="binaural_advance_payment_settings">
                    <setting help="Passive and reconcilable accounting account">
                        <field name="advance_customer_account_id" />
                    </setting>
                    <setting help="Active and reconcilable accounting account">
                        <field name="advance_supplier_account_id" />
                    </setting>

                    <setting help="Revalorice all payments in Bsf">
                        <field name="revalorize_payments_vef" />
                    </setting>
                </block>

                <block title="Advance Payment IGTF" name="binaural_igtf_settings">
                    
                        <setting string="IGTF Journal">
                            <field name="advance_payment_igtf_journal_id" domain="[('type', '=', 'general')]"/>
                        </setting>
                        <setting string="IGTF Percentage">
                            <field name="igtf_percentage" />
                        </setting>

                        <setting string="Show in Sale Order" help="Show suggestion based on total amount of the Order">
                            <field name="show_igtf_suggested_sale_order" />
                        </setting>
                        <setting string="Show in Invoice" help="Show suggestion based on total amount of the Invoice">
                            <field name="show_igtf_suggested_account_move" />
                        </setting>

                        <setting string="Customer IGTF Account">
                            <field name="customer_account_igtf_id" />
                        </setting>
                        <setting string="Supplier IGTF Account">
                            <field name="supplier_account_igtf_id" />
                        </setting>
                    
                </block>

            </xpath>
        </field>
    </record>
</odoo>