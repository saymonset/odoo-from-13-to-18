<odoo>
    <record id="res_config_settings_view_form_l10n_ve_stock" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.l10n.ve.stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_ve_base.l10n_ve_base_view_res_config_settings" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='l10n_ve_base']" position="inside">
                <block title="Stock Settings" name="l10n_ve_stock_block">
                    <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_stock_group_product_available_quantity_on_sale">
                        <div class="o_setting_left_pane">
                            <field name="group_product_available_quantity_on_sale" class="oe_inline" required="1"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="group_product_available_quantity_on_sale" />
                            <div class="text-muted">Allows to show the available quantity (Total minus reserved) in both product template and variant of it.</div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_stock_use_main_warehouse">
                        <div class="o_setting_left_pane">
                            <field name="use_main_warehouse"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="use_main_warehouse"/>
                            <div class="text-muted">
                                Define a main sell's warehouse.
                            </div>
                            <div class="content-group">
                                <div class="mt16" invisible="not use_main_warehouse">
                                    <field name="main_warehouse_id" class="oe_inline" required="use_main_warehouse"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_stock_change_weight">
                        <div class="o_setting_left_pane">
                            <field name="change_weight" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="change_weight"/>
                            <div class="text-muted">
                                Allow changing weight during picking
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_stock_validate_without_product_quantity">
                        <div class="o_setting_left_pane">
                            <field name="validate_without_product_quantity" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="validate_without_product_quantity" />
                            <div class="text-muted">
                                If you have more than the quantity on stock dont allow
                                transfer/sell.
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_stock_not_allow_negative_inventory_adjustments">
                        <div class="o_setting_left_pane">
                            <field name="not_allow_negative_inventory_adjustments"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="not_allow_negative_inventory_adjustments"/>
                            <div class="text-muted">
                                <strong>When marked:</strong> Negative inventory adjustments (from both the product and inventory/operations views) will not be allowed.<br/>
                                <strong>When unchecked:</strong> Negative inventory adjustments will be allowed (both from the product view and from inventory/operations).
                            </div>
                        </div>
                    </div>
                     	<div class="col-12 col-lg-6 o_setting_box">
						<div class="o_setting_left_pane">
							<field name="allow_scrap_more_than_available"/>
						</div>
						<div class="o_setting_right_pane">
							<label for="allow_scrap_more_than_available"/>
							<div class="text-muted"> Allow to scrap more than available quantity in stock. </div>
						</div>
					</div> 

                   <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="not_allow_scrap_more_than_what_was_manufactured" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="not_allow_scrap_more_than_what_was_manufactured"/>
                            <div class="text-muted">
                                <strong>When marked:</strong> No more than what is manufactured in an order may be scrapped.<br/>
                                <strong>When unchecked:</strong> More than what is manufactured in an order may be scrapped.
                            </div>
						</div>
					</div>
                    <div class="col-12 col-lg-6 o_setting_box">
						<div class="o_setting_left_pane">
							<field name="not_allow_negative_stock_movement"/>
						</div>
						<div class="o_setting_right_pane">
							<label for="not_allow_negative_stock_movement"/>
							<div class="text-muted">
								<span>Do not allow negative stock in internal movements</span>
							</div>
						</div>
					</div>
                    <div class="col-12 col-lg-12 o_setting_box" id="l10n_ve_settings_stock_use_free_qty_odoo">
                        <div class="o_setting_left_pane">
                            <field name="use_free_qty_odoo" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="use_free_qty_odoo"/>
                            <div class="text-muted">
                                <strong>When marked:</strong> On the product sheet Take into account all the the locations to calculate Available Quantities
                                <br/>
                                <strong>When unchecked:</strong> The quantity of products will be filtered ('Available quantity') by parent and child locations that are only of Type 'Stock'
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_stock_validate_without_product_quantity">
                        <div class="o_setting_left_pane">
                            <field name="limit_product_qty_out" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="limit_product_qty_out" />
                            <div class="text-muted">
                               Maximum quantity of products to be sold per stock picking.
                            </div>
                        </div>
                    </div>
                </block>
            </xpath>
        </field>
    </record>
</odoo>