<odoo>
    <record id="res_config_settings_view_form_invoice_cron" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.invoice.cron</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_ve_invoice.view_res_config_settings_l10n_ve_invoice" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='l10n_ve_invoice_block']" position="inside">
                <separator string="Programming Automatic Invoices" />
                <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_invoice_cron_type">
                    <div class="o_setting_right_pane">
                        <group colspan="4" col="4">
                            <field name="invoice_cron_type" class="oe_inline"/>
                        </group>
                        <div class="text-muted">Select the type of invoice</div>
                    </div>
                </div>
                <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_invoice_cron_time">
                    <div class="o_setting_right_pane">
                        <group colspan="4" col="4">
                            <field name="invoice_cron_time" class="oe_inline" widget="float_time"/>
                        </group>
                        <div class="text-muted">Exact time to generate the invoice</div>
                    </div>
                </div>
                <separator string="Journals for Invoices from Picking" />
                <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_invoice_journal">
                    <div class="o_setting_left_pane"/>
                    <div class="o_setting_right_pane">
                        <span class="o_form_label">Journals</span>
                        <span 
                            class="fa fa-lg fa-building-o"
                            title="Values set here are company-specific."
                            aria-label="Values set here are company-specific."
                            role="img"
                        />
                        <div class="text-muted">
                            Journals which should apply for the invoice
                            creation from stock picking
                        </div>
                        <div class="content-group">
                            <div class="row mt16">
                                <label 
                                    string="Sales Journal"
                                    for="customer_journal_id"
                                    class="col-lg-3 o_light_label"
                                />
                                <field 
                                    name="customer_journal_id"
                                    domain="[('type', '=', 'sale')]"
                                />
                            </div>
                            <br/>
                            <div class="row">
                                <label 
                                    string="Purchase Journal"
                                    for="vendor_journal_id"
                                    class="col-lg-3 o_light_label"
                                />
                                <field 
                                    name="vendor_journal_id"
                                    domain="[('type', '=', 'purchase')]"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
    
    <record id="l10n_ve_stock_inherit_l10n_ve_stock_account" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.l10n_ve_stock_account</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_ve_base.l10n_ve_base_view_res_config_settings"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='l10n_ve_stock_block']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_stock_indexed_dispatch_guide">
                    <div class="o_setting_left_pane">
                        <field name="indexed_dispatch_guide" />
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="indexed_dispatch_guide" />
                        <div class="text-muted">
                            <strong>When marked:</strong> The format of the dispatch guide will use the conversion rate based on the date done of the stock picking.
                            <strong>When unmarked:</strong> It will use the date of the sale order.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_hide_disc_field_dispatch_guide">
                    <div class="o_setting_left_pane">
                        <field name="hide_disc_field_dispatch_guide"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="hide_disc_field_dispatch_guide"/>
                        <div class="text-muted">
                            If checked, the discount field will be hidden in the dispatch guide.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_hide_weight_field_dispatch_guide">
                    <div class="o_setting_left_pane">
                        <field name="hide_weight_field_dispatch_guide"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="hide_weight_field_dispatch_guide"/>
                        <div class="text-muted">
                            If checked, the weight field will be hidden in the dispatch guide.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6 o_setting_box" id="l10n_ve_settings_donation_account_id">
                    <div class="o_setting_right_pane">
                        <label for="donation_account_id"/>
                        <div class="text-muted">
                            Account to be used for donation flow.
                        </div>
                        <div class="content-group">
                            <div class="mt16">
                                <field name="donation_account_id"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>