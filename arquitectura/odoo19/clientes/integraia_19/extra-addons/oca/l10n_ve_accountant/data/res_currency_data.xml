<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Moneda Bolívar Venezolano (VES) -->
        <record id="base.VES" model="res.currency">
            <field name="name">VES</field>
            <field name="symbol">Bs.</field>
            <field name="position">before</field>
            <field name="rounding">0.01</field>
            <field name="active">True</field>
        </record>

        <!-- Moneda Dólar Americano (USD) -->
        <record id="base.USD" model="res.currency">
            <field name="name">USD</field>
            <field name="symbol">$</field>
            <field name="position">before</field>
            <field name="rounding">0.01</field>
            <field name="active">True</field>
        </record>

        <!-- Tasa de cambio diaria (placeholder) -->
        <record id="rate_ves_usd" model="res.currency.rate">
            <field name="currency_id" ref="base.USD"/>
            <field name="rate">1.0</field>
            <field name="name">2024-01-01</field>
            <field name="company_id" ref="base.main_company"/>
        </record>
    </data>
</odoo>