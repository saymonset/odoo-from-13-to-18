<odoo>
    <record model="res.groups.privilege" id="res_groups_privilege_category_hidden">
        <field name="name">Technically</field>
        <field name="sequence">100</field>
        <field name="category_id" ref="base.module_category_hidden" />
    </record>
    <record id="group_fiscal_config_user" model="res.groups">
        <field name="name">Configuraciones fiscales usuario</field>
        <field name="privilege_id" ref="account.res_groups_privilege_accounting" />
        <field name="user_ids" eval="[(4, ref('base.user_root')),(4,ref('base.user_admin'))]" />
    </record>
    <record id="group_fiscal_config_support" model="res.groups">
        <field name="name">Configuraciones fiscales soporte</field>
        <field name="privilege_id" ref="account.res_groups_privilege_accounting" />
        <field name="implied_ids" eval="[(4, ref('group_fiscal_config_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')),(4,ref('base.user_admin'))]" />
    </record>
    <record id="group_support_user" model="res.groups">
        <field name="name">Support User (Journals)</field>
        <field name="user_ids" eval="[(4, ref('base.user_root')),(4,ref('base.user_admin'))]" />
    </record>
    <record id="group_foreign_currency_view_accountant" model="res.groups">
        <field name="name">Foreign Currency View Accountant</field>
    </record>
</odoo>
