<odoo>
    <odoo>
        <record id="tax_support_no_archive_rule" model="ir.rule">
            <field name="name">Impuestos: No archivar para Soporte Fiscal</field>
            <field name="model_id" ref="account.model_account_tax"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('group_fiscal_config_support'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>
        <record id="account_move_unlink_draft_only" model="ir.rule">
            <field name="name">delete invoice if draft</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="domain_force">[('state', '=', 'draft')]</field>
            <field name="groups" eval="[(4, ref('account.group_account_invoice'))]"/>
            <field name="perm_unlink" eval="True"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
        </record>
    </odoo>
</odoo>