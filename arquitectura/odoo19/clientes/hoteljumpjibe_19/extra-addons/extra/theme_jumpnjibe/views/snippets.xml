<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Snippet: Tarjeta de Habitación -->
    <template id="s_room_card" name="Room Card">
        <section class="s_room_card pt32 pb32">
            <div class="container">
                <div class="card" style="border: 1px solid #004b66; border-radius: 8px; overflow: hidden;">
                    <img src="/theme_jumpnjibe/static/src/img/hab-grande-mar.jpg" class="card-img-top img img-fluid" alt="Habitación"/>
                    <div class="card-body bg-caribbean-bg">
                        <h5 class="card-title text-caribbean-dark">Habitación Deluxe</h5>
                        <p class="card-text">Características: cama king, vista al mar, baño privado.</p>
                        <p class="card-text text-caribbean-primary font-weight-bold" style="font-weight: bold;">$120 por noche</p>
                        <a href="/habitaciones" class="btn btn-primary" style="background-color: #007799; border-color: #007799;">Ver más</a>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!-- Snippet: Tarjeta Testimonial -->
    <template id="s_testimonial_card" name="Testimonial Card">
        <section class="s_testimonial_card pt32 pb32">
            <div class="container">
                <div class="card bg-caribbean-light" style="border: 1px solid #004b66; border-radius: 8px; overflow: hidden;">
                    <div class="card-body">
                        <p class="card-text font-italic">"El mejor lugar para quedarse en El Yaque. Viento perfecto y atención inigualable."</p>
                        <h6 class="card-subtitle mb-2 text-muted">- Juan Pérez</h6>
                        <p class="card-text text-caribbean-primary">★★★★★</p>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!-- Add snippets to the Website Builder -->
    <template id="snippets" inherit_id="website.snippets" name="Jump N Jibe Snippets">
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="theme_jumpnjibe.s_room_card" string="Room Card" group="content" t-thumbnail="/website/static/src/img/snippets_thumbs/s_features.svg"/>
            <t t-snippet="theme_jumpnjibe.s_testimonial_card" string="Testimonial Card" group="content" t-thumbnail="/website/static/src/img/snippets_thumbs/s_blockquote.svg"/>
        </xpath>
    </template>
</odoo>
