<odoo>
    <data>
        <record id="view_retention_iva_form_l10n_ve_payment_extension" model="ir.ui.view">
            <field name="name">Retention IVA client form</field>
            <field name="model">account.retention</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Retention" duplicate="false">
                    <header>
                        <field name="state" invisible="1" />
                        <button name="action_draft" type="object"
                            string="Convert to draft"
                            invisible="type != 'out_invoice' or state != 'cancel'" />
                        <button name="action_post" type="object" invisible="state != 'draft'" string="Approve"
                            class="oe_highlight" />
                        <button name="action_cancel" type="object" invisible="state != 'emitted'" string="Cancel"
                            confirm="Are you sure you want to cancel this voucher? The associated accounting entries will be reversed" />
                        <field name="state" widget="statusbar" nolabel="1" />
                    </header>
                    <sheet>
                        <group colspan="4" col="4">
                            <!-- Invisible fields -->
                            <field name="name" invisible="1" force_save="1" />
                            <field name="available_invoice_ids" invisible="1" />
                            <field name="actual_invoice_ids" invisible="1" />
                            <field name="original_lines_per_invoice_counter" invisible="1" />
                            <field name="base_currency_is_vef" invisible="1" />
                            <field name="company_currency_id" invisible="1" />
                            <field name="foreign_currency_id" invisible="1" />
                            <field name="type_retention" invisible="1" force_save="1" />
                            <field name="is_third_party_retention" readonly="1" invisible="type != 'in_invoice'"/>
                            <field name="type" force_save="1" select="2" />
                            <field name="company_id" invisible="1"/>
                            <field name="partner_id" on_change="onchange_partner_id(type,partner_id)"
                                select="1"
                                invisible="not type"
                                readonly="state in ['emitted', 'cancel']" />
                            <field name="date_accounting" select="1"
                                readonly="state in ['emitted', 'cancel']" />
                            <field name="number" force_save="1"
                                readonly="type == 'in_invoice' or state in ['emitted', 'cancel']"
                                required="type == 'out_invoice'"/>
                            <field name="correlative" force_save="1"
                                invisible="1"
                                readonly="type == 'in_invoice'" />
                            <field name="date"
                                readonly="type == 'in_invoice' or state in ['emitted', 'cancel']" />
                        </group>
                        <notebook>
                            <page name="retention_lines" string="Retention Lines">
                                <field colspan="4" name="retention_line_ids" nolabel="1"
                                    readonly="state in ['emitted', 'cancel']">
                                    <list string="Retention Lines" editable="bottom">
                                        <!-- Invisible fields -->
                                        <field name="invoice_type" column_invisible="True" />
                                        <field name="company_currency_id" column_invisible="True" />
                                        <field name="foreign_currency_id" column_invisible="True" />
                                        <field name="name" required="1"/>
                                        <field name="move_id"
                                            options="{'no_create': True}"
                                            force_save="1"
                                            domain="[
                                                ('id', 'in', parent.available_invoice_ids)  
                                            ]"/>
                                        <field name="company_id" optional="hide"
                                            groups="base.group_multi_company" />
                                        <field name="aliquot" />
                                        <field name="related_percentage_tax_base" optional="hide" />
                                        <!-- Amounts -->
                                        <field
                                            name="invoice_total"
                                            column_invisible="not parent.base_currency_is_vef"
                                            widget="monetary"
                                            options="{'currency_field': 'company_currency_id'}"
                                            />
                                        <field
                                            name="invoice_amount"
                                            widget="monetary"
                                            options="{'currency_field': 'company_currency_id'}"
                                            column_invisible="not parent.base_currency_is_vef"/>
                                        <field
                                            name="iva_amount"
                                            widget="monetary"
                                            options="{'currency_field': 'company_currency_id'}"
                                            column_invisible="not parent.base_currency_is_vef"/>
                                        <field
                                            name="retention_amount"
                                            widget="monetary"
                                            options="{'currency_field': 'company_currency_id'}"
                                            column_invisible="not parent.base_currency_is_vef"/>
                                        <!-- Foreign Amounts -->
                                        <field
                                            name="foreign_invoice_amount"
                                            widget="monetary"
                                            options="{'currency_field': 'foreign_currency_id'}"
                                            column_invisible="parent.base_currency_is_vef"/>
                                        <field
                                            name="foreign_iva_amount"
                                            widget="monetary"
                                            options="{'currency_field': 'foreign_currency_id'}"
                                            column_invisible="parent.base_currency_is_vef"/>
                                        <field
                                            name="foreign_invoice_total"
                                            widget="monetary"
                                            options="{'currency_field': 'foreign_currency_id'}"
                                            column_invisible="parent.base_currency_is_vef"/>
                                        <field
                                            name="foreign_retention_amount"
                                            widget="monetary"
                                            options="{'currency_field': 'foreign_currency_id'}"
                                            column_invisible="parent.base_currency_is_vef"/>
                                        <field name="foreign_currency_rate" optional="hide" />
                                    </list>
                                </field>
                                <group col="2" colspan="2"
                                    invisible="not base_currency_is_vef">
                                    <field
                                        name="total_invoice_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'company_currency_id'}"
                                    />
                                    <field
                                        name="total_iva_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'company_currency_id'}"
                                    />
                                    <field
                                        name="total_retention_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'company_currency_id'}"
                                    />
                                </group>
                                <group col="2" colspan="2"
                                    invisible="base_currency_is_vef">
                                    <field
                                        name="foreign_total_invoice_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'foreign_currency_id'}"
                                    />
                                    <field
                                        name="foreign_total_iva_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'foreign_currency_id'}"
                                    />
                                    <field
                                        name="foreign_total_retention_amount"
                                        widget="monetary"
                                        options="{'currency_field': 'foreign_currency_id'}"
                                    />
                                </group>
                            </page>
                            <page name="Payments" string="payments">
                                <field name="payment_ids" nolabel="1"
                                    readonly="state in ['emitted', 'cancel']">
                                    <list string="Payments" editable="bottom">
                                        <field name="company_id" optional="hide"/>
                                        <field name="date" />
                                        <field name="name"/>
                                        <field name="amount" />
                                        <field name="state" />
                                        <field name="foreign_rate" optional="hide" />
                                        <field name="payment_type" optional="hide" />
                                        <field name="payment_type_retention" optional="hide" />
                                        <field name="partner_type" optional="hide" />
                                        <field name="partner_id" optional="hide" />
                                        <field name="currency_id" optional="hide" />
                                        <field name="is_retention" optional="hide" />
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="view_retention_iva_list_l10n_ve_payment_extension" model="ir.ui.view">
            <field name="name">Retention IVA client list</field>
            <field name="model">account.retention</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Retention">
                    <field name="number" />
                    <field name="type" />
                    <field name="partner_id" />
                    <field name="date" />
                    <field name="date_accounting" />
                    <field name="is_third_party_retention" optional="show" />
                    <field name="company_id" optional="hide" groups="base.group_multi_company" />
                    <field name="state" />
                </list>
            </field>
        </record>
        <!--View:
        Search: Retenciones client-->
        <record id="view_retention_iva_search_l10n_ve_payment_extension" model="ir.ui.view">
            <field name="name">IVA Retention</field>
            <field name="model">account.retention</field>
            <field name="arch" type="xml">
                <search string="IVA Retention">
                    <field name="number" string="Number" filter_domain="[('number','ilike',self)]" />
                    <field name="partner_id" string="Business Name" filter_domain="[('partner_id','ilike',self)]" />
                    <field name="date" string="Vocher date" filter_domain="[('date','ilike',self)]" />
                    <field name="date_accounting" string="Fecha Contable" filter_domain="[('date_accounting','ilike',self)]" />
                    <filter name="is_third_party_retention" string="Third Party Retention" domain="[('is_third_party_retention', '=', True)]" />
                    <separator/>
                    <filter name="group_state" string="Group by State" context="{'group_by':'state'}" />
                    <filter name="group_partner" string="Group by Business Name" context="{'group_by':'partner_id'}" />
                    <filter name="group_date_accounting" string="Group by Fecha Contable" context="{'group_by':'date_accounting'}" />
                    <filter name="group_is_third_party_retention" string="Group by Third Party Billing" context="{'group_by':'is_third_party_retention'}" />
                </search>
            </field>
        </record>
        <record id="action_retention_iva_client" model="ir.actions.act_window">
            <field name="name">IVA Retention Clients</field>
            <field name="res_model">account.retention</field>
            <field name="binding_view_types">list</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids"
                eval="[(5, 0, 0), 
                        (0, 0, {'view_mode': 'list', 'view_id': ref('view_retention_iva_list_l10n_ve_payment_extension')}),
                        (0, 0, {'view_mode': 'form', 'view_id': ref('view_retention_iva_form_l10n_ve_payment_extension')})]" />
            <field name="context">{"default_type":'out_invoice', "default_type_retention":'iva'}</field>
            <field name="domain">[('type_retention', '=', 'iva'), ('type', '=', 'out_invoice')]</field>
        </record>
        <record id="action_retention_iva_supplier" model="ir.actions.act_window">
            <field name="name">IVA Retention Suppliers</field>
            <field name="res_model">account.retention</field>
            <field name="binding_view_types">list</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids"
                eval="[(5, 0, 0), 
                        (0, 0, {'view_mode': 'list', 'view_id': ref('view_retention_iva_list_l10n_ve_payment_extension')}),
                        (0, 0, {'view_mode': 'form', 'view_id': ref('view_retention_iva_form_l10n_ve_payment_extension')})]" />
            <field name="context">{"default_type":'in_invoice', "default_type_retention":'iva'}</field>
            <field name="domain">[('type_retention', '=', 'iva'), ('type', '=', 'in_invoice')]</field>
        </record>
    </data>
</odoo>